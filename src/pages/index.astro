---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

export const prerender = true;

const posts = await getCollection("posts");
---

<Layout title="Posts">
	<div class="mx-auto min-h-full max-w-2xl px-4 py-12 sm:px-6 sm:py-16">
		<header class="mb-10 border-b border-stone-200 pb-8">
			<p class="text-sm font-medium uppercase tracking-wide text-teal-800/90">
				brollin.space
			</p>
			<h1
				class="mt-2 text-3xl font-semibold tracking-tight text-stone-900 sm:text-4xl"
			>
				Ben's Health Blog
			</h1>
			<p class="mt-3 max-w-lg text-pretty text-stone-600 leading-relaxed">
				Here are some blog posts about my health and how it has changed over time.
			</p>
		</header>

		<main>
			{
				posts.length === 0 ? (
					<p class="rounded-lg border border-dashed border-stone-300 bg-white/60 px-4 py-8 text-center text-stone-500">
						No posts yet.
					</p>
				) : (
					<ul class="divide-y divide-stone-200 rounded-xl border border-stone-200 bg-white shadow-sm">
						{posts.map((post) => (
							<li>
								<a
									href={`/posts/${post.id}`}
									class="block px-4 py-4 transition-colors hover:bg-stone-50 sm:px-5"
								>
									<span class="font-medium text-stone-900 underline-offset-2 hover:underline">
										{post.data.title}
									</span>
									<span
										class="mt-0.5 block text-sm text-stone-500"
										aria-hidden="true"
									>
										Read post →
									</span>
								</a>
							</li>
						))}
					</ul>
				)
			}
		</main>
	</div>
</Layout>
